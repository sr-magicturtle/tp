<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" spacing="20" minHeight="165" alignment="CENTER_LEFT"
      styleClass="person-card"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <padding>
    <Insets top="24" right="28" bottom="24" left="52" />
  </padding>

  <VBox alignment="CENTER_LEFT" spacing="20" prefWidth="280" minWidth="280">
    <padding>
      <Insets top="6" bottom="6" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="6">
      <Label fx:id="id" styleClass="person-index-label">
        <minWidth>
          <Region fx:constant="USE_PREF_SIZE" />
        </minWidth>
      </Label>
      <Label fx:id="name" text="Name" styleClass="person-name-label" />

      <Label fx:id = "circleBadge"
             text = "client"
             styleClass= "circle-badge"
             visible="false" managed="false"/>
    </HBox>

    <VBox alignment="CENTER_LEFT" spacing="12">
      <Label fx:id="phone" text="Phone" styleClass="person-detail-label" />
      <HBox alignment="CENTER_LEFT" spacing="0">
        <Label text="Email: " styleClass="person-detail-label" />
        <Label fx:id="email" text="email@example.com" styleClass="person-email-label" />
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="0">
        <Label text="Follow up: " styleClass="person-detail-label" />
        <Label fx:id="followUpDate" text="-" styleClass="person-detail-label" />
      </HBox>

    </VBox>
  </VBox>

  <VBox alignment="CENTER_LEFT" spacing="8" prefWidth="420" minWidth="420">
    <Label fx:id="address" text="Address" styleClass="person-address-label" wrapText="true" />
    <HBox fx:id="notesRow" alignment="CENTER_LEFT" spacing="6" visible="false" managed="false">
    </HBox>
  </VBox>

  <Region HBox.hgrow="ALWAYS" />

  <FlowPane fx:id="tags" alignment="TOP_RIGHT" hgap="10" vgap="10" prefWrapLength="220" prefWidth="220" />
</HBox>
